# Copy this file to .env and fill in real values. NEVER commit .env.
# In production these live in GitHub Actions secrets (scraper) and Vercel
# environment variables (dashboard). See SETUP.md.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase TRANSACTION POOLER connection string (port 6543), from
# Supabase Dashboard → Project Settings → Database → Connection string → "Transaction".
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres

# ── Scraping / enrichment API keys (REQUIRED) ─────────────────────────────────
# Reissue these before first use — the originals were exposed in source.
APIFY_API_TOKEN=
SCRAPINGBEE_API_KEY=
OPENAI_API_KEY=

# ── Optional overrides (sensible defaults exist in code) ──────────────────────
# APIFY_ACTOR_ID=memo23/facebook-ads-library-scraper-cheerio
# BUCKET_NAME=aporia-unleash

# ── Google service-account key files (paths on disk) ──────────────────────────
# The JSON key files themselves are secrets — keep them out of git.
SERVICE_ACCOUNT_FILE_SHEETS=smart-surf-295322-88ad90affe77.json
SERVICE_ACCOUNT_FILE_STORAGE=uplift-283910-79cf8c0b12d4.json

# ── Google Sheets IDs (still used for reference/verticals lookups in Phase 1) ─
# SPREADSHEET_ID=
# REFERENCE_SPREADSHEET_ID=
# VERTICALS_SPREADSHEET_ID=

# Dashboard login gate (Next.js): shared team passcode + random cookie-signing secret
DASHBOARD_PASSCODE=
SESSION_SECRET=

# Optional: a second passcode granting read-only (viewer) access
DASHBOARD_VIEWER_PASSCODE=
# Optional: lets the Control Room 'Run now' button trigger the scrape workflow
GH_REPO=yoav-prog/ad-lib-dashboard
GH_DISPATCH_TOKEN=

# Copy this file to .env and fill in real values. NEVER commit .env.
# In production these live in GitHub Actions secrets (scraper) and Vercel
# environment variables (dashboard). See SETUP.md.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase TRANSACTION POOLER connection string (port 6543), from
# Supabase Dashboard → Project Settings → Database → Connection string → "Transaction".
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres

# ── Scraping / enrichment API keys (REQUIRED) ─────────────────────────────────
# Reissue these before first use — the originals were exposed in source.
APIFY_API_TOKEN=
SCRAPINGBEE_API_KEY=
OPENAI_API_KEY=

# ── Optional overrides (sensible defaults exist in code) ──────────────────────
# APIFY_ACTOR_ID=memo23/facebook-ads-library-scraper-cheerio
# BUCKET_NAME=aporia-unleash
# Soft time budget per scrape run, in minutes (default 45). When it runs out
# the run finishes cleanly and leaves unfinished domains due for the next tick.
# RUN_TIME_BUDGET_MINUTES=45

# ── Google service-account key files (paths on disk) ──────────────────────────
# The JSON key files themselves are secrets — keep them out of git.
SERVICE_ACCOUNT_FILE_SHEETS=smart-surf-295322-88ad90affe77.json
SERVICE_ACCOUNT_FILE_STORAGE=uplift-283910-79cf8c0b12d4.json

# ── Google Sheets IDs (still used for reference/verticals lookups in Phase 1) ─
# SPREADSHEET_ID=
# REFERENCE_SPREADSHEET_ID=
# VERTICALS_SPREADSHEET_ID=

# ── Dashboard accounts (Next.js) ──────────────────────────────────────────────
# People sign in with an email and a password they set from an emailed invite.
# Manage everyone at /admin; bootstrap the first admin once at /setup.

# Random 32+ char string that signs the emergency-access cookie. Sessions do not
# need it (they are opaque tokens checked against the database), so it is only
# required alongside BREAK_GLASS_PASSCODE below. There is no insecure fallback:
# without it, emergency access is simply off.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# The dashboard's stable public URL. REQUIRED: invite and reset emails put an
# absolute link in the message, and Vercel's built-in URL vars point at the
# individual deployment, not the production domain.
APP_URL=https://your-dashboard.vercel.app

# Only addresses at this domain can be invited or sign in. Enforced at invite,
# at invite acceptance, and at login. If it is unset the app refuses ALL
# sign-ins, which is the safe direction to fail.
ALLOWED_EMAIL_DOMAIN=aporianetworks.com

# The address /setup mails the very first admin invite to. It is the only
# address that page will ever send to.
ADMIN_EMAIL=you@aporianetworks.com

# Optional emergency door for "the only admin is locked out and email is down".
# Grants user management only, for 30 minutes, never the ad data, and every use
# is logged. Leave blank to disable it entirely. Use 24+ random characters.
BREAK_GLASS_PASSCODE=

# ── Transactional email (invites and password resets) ─────────────────────────
# SMTP through the team's existing Google Workspace account, so no new service.
# SMTP_PASS is a Google App Password, not the account password (needs 2FA on).
# Port 465 is implicit TLS; 587 would use STARTTLS. Vercel allows both (it
# blocks only port 25).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@aporianetworks.com
SMTP_PASS=
EMAIL_FROM=you@aporianetworks.com

# Optional: lets the Control Room 'Run now' button trigger the scrape workflow
GH_REPO=yoav-prog/ad-lib-dashboard
GH_DISPATCH_TOKEN=
